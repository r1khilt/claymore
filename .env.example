# Claymore environment template. Copy to `.env` (gitignored) and fill in.
# NEVER commit a real .env. Secrets are injected at runtime, never in code/graph/logs
# (SECURITY.md §7). Ports match docker-compose.yml.

# --- Phase 0: core (boots the skeleton on these alone) ---
ANTHROPIC_API_KEY=            # sk-ant-...   agent + Graphiti extraction (console.anthropic.com)
VOYAGE_API_KEY=              # embeddings for hybrid search (dashboard.voyageai.com)
TELEGRAM_BOT_TOKEN=          # dev/pilot channel (@BotFather /newbot)
TELEGRAM_WEBHOOK_SECRET=      # random; registered via setWebhook, echoed back on each delivery
TELEGRAM_ENROLLMENTS=        # telegram_user_id:lab_id:user_id, comma-separated
WHATSAPP_ENROLLMENTS=        # phone:lab_id:user_id, comma-separated
DATABASE_URL=postgresql+asyncpg://claymore:claymore@localhost:5432/claymore
REDIS_URL=redis://localhost:6380/0       # Arq queue + caches (compose maps redis -> 6380)
FALKORDB_URI=redis://localhost:6379      # Graphiti backend (compose maps falkordb -> 6379)

# --- Phase 1: ingestion ---
COMPOSIO_API_KEY=            # app.composio.dev  (Slack/Gmail/GitHub/Notion/Drive/Docs OAuth)
GRANOLA_API_KEY=             # grn_...  (Business plan) meeting notes + transcripts
# CODELOGS_PATHS=/path/to/claude-code/logs,/path/to/codex/logs

# --- Phase 2: messaging (WhatsApp via Twilio sandbox; SMS post-hackathon) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=+14155238886   # Twilio WhatsApp sandbox sender (bare E.164)
PUBLIC_BASE_URL=                    # public origin for webhook signature verify (ngrok/Fly)

# --- Phase 3: execution (compute) ---
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
E2B_API_KEY=
# NVIDIA_NGC_API_KEY=

# --- cost / behavior knobs (R6) ---
EXTRACTION_MODEL=claude-haiku-4-5-20251001   # cheap model for per-episode extraction
QUERY_MODEL=claude-opus-4-8                   # strong model for query reasoning/planning
GRAPHITI_SEMAPHORE_LIMIT=10                   # raise for throughput, lower to avoid 429s
PER_LAB_MONTHLY_SPEND_CAP_USD=

# --- feature flags (default OFF until the layer is built + eval'd; R1) ---
INGEST_ENABLED=false
ACT_ENABLED=false
MCP_OUT_ENABLED=false
EXEC_COMPUTE_ENABLED=false
EXEC_WETLAB_ENABLED=false

# --- runtime ---
ENV=local          # local | staging | prod
LOG_LEVEL=INFO

# --- admin API (ingest triggers; fail-closed when empty) ---
ADMIN_API_TOKEN=             # random hex; required header X-Claymore-Admin-Token on /admin/*
COMPOSIO_USER_ID=            # Composio entity id the connected accounts live under
LAB_ROSTER_JSON=             # JSON list of Users seeding identity resolution (R11)

# --- web UI (browser dashboard in web/; POST /api/ask -> real Ask loop) ---
WEB_API_ENABLED=false        # true to let the web/ dashboard hit the real graph (no per-msg auth)
WEB_LAB_ID=lab1              # lab the web dashboard queries as
WEB_USER_ID=web-user         # user identity the web dashboard queries as (visibility scope)

# Local single-user store for the dashboard (chats/settings/profile/keys/metrics/errors). A JSON
# file in the user's own folder, git-ignored — NOT the Postgres app-state store. Default: ~/.claymore
# CLAYMORE_LOCAL_DIR=~/.claymore   # override where local.json lives (Settings can hold the Anthropic key)
